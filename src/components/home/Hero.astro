---
import Button from '../shared/Button.astro';
import Icon from '../shared/Icon.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/img/cris_capricho.jpeg';
---

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden pt-20">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-black/40 z-10" />
    <Image
      src={heroImage}
      alt="Minimalist concrete skyscraper reaching towards a clear sky"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      widths={[640, 1024, 1280, 1600]}
      sizes="100vw"
      quality={75}
      format="webp"
    />
  </div>

  <!-- Content -->
  <div class="relative z-20 text-center px-6">
    <h1 class="text-white text-6xl md:text-9xl font-black leading-none tracking-tight mb-6 uppercase">
      Eterea <br />Producciones
    </h1>
    <p class="text-white/90 text-lg md:text-l font-light max-w-2xl mx-auto mb-10 tracking-wide uppercase">
      Tu empresa de artes escenicas y audiovisuales en Cantabria <br/> Llevamos tus proyectos al siguiente nivel
    </p>
    <p class="text-white/90 text-lg md:text-xl font-light max-w-2xl mx-auto mb-10 tracking-wide uppercase">
      
    </p>
    <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
      <Button href="/projects" variant="primary" size="lg">Si pulsas aqui te ladra sur</Button>
      <Button href="/about" variant="secondary" size="lg">Este boton no hace nada</Button>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <Icon name="chevron-down" size={32} class="text-white" />
  </div>
</section>