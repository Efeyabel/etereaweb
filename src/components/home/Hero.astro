---
import Button from '../shared/Button.astro';
import Icon from '../shared/Icon.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/img/cris_capricho.jpeg';
---

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden pt-20">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-black/50 z-10" />
    <Image
      src={heroImage}
      alt="Eterea Producciones Hero Background"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      widths={[640, 1024, 1280, 1600]}
      sizes="100vw"
      quality={75}
      format="webp"
    />
  </div>

  <!-- Content -->
  <div class="relative z-20 text-center px-4 sm:px-6 w-full max-w-5xl mx-auto">
    <h1 class="text-white text-4xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black leading-tight sm:leading-none tracking-tighter mb-6 uppercase break-words">
      Etérea <br class="hidden sm:block" />Producciones
    </h1>
    
    <p class="text-white/90 text-base sm:text-lg md:text-xl font-light max-w-2xl mx-auto mb-8 tracking-wide uppercase balance">
      Tu empresa de artes escénicas y audiovisuales en Cantabria. <br class="hidden md:block"/> Llevamos tus proyectos al siguiente nivel.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href="/projects" variant="primary" size="lg" class="w-full sm:w-auto">Boton para que Sur ladre</Button>
      <Button href="/about" variant="secondary" size="lg" class="w-full sm:w-auto">Este no hace nada</Button>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <Icon name="chevron-down" size={32} class="text-white" />
  </div>
</section>

<style>
  /* Un pequeño truco de CSS moderno para que los párrafos no dejen viudas feas */
  .balance {
    text-wrap: balance;
  }
</style>