---
import Container from '../shared/Container.astro';
import Icon from '../shared/Icon.astro';
import Logo from '../shared/Logo.astro';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 w-full z-50 bg-stone-200 dark:bg-background-dark/90 backdrop-blur-md border-b border-slate-100 dark:border-slate-800">
  <Container class="h-20 flex items-center justify-between">
    <!-- Logo & Brand -->
    <a href="/" class="flex items-center gap-3 group cursor-pointer h-full">
      <div class="flex items-center text-slate-900 dark:text-slate-100">
          {/* Usamos el tamaño xs que has creado para que encaje mejor en los 80px de altura */}
          <Logo size="xs" />
      </div>
      <h1 class="text-xl font-black tracking-tighter uppercase leading-none">
        Etérea Producciones
      </h1>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-10">
      <a 
        href="/" 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/' 
            ? "text-primary" 
            : "text-secondary hover:text-primary dark:hover:text-primary"
        ]}
      >
        Home
      </a>
      <a 
        href="/projects" 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/projects' || currentPath.startsWith('/projects/')
            ? "text-primary" 
            : "text-secondary hover:text-primary dark:hover:text-primary"
        ]}
      >
        Proyectos
      </a>
      <a 
        href="/about" 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/about'
            ? "text-primary" 
            : "text-secondary hover:text-primary dark:hover:text-primary"
        ]}
      >
        Entradas
      </a>
    </nav>

    <!-- CTA & Mobile Trigger -->
    <div class="flex items-center gap-4">
      <a 
        href="/contact" 
        class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded text-sm font-bold uppercase tracking-wider transition-all flex items-center gap-2 shadow-sm"
      >
        <Icon name="send" size={16} />
        <span class="hidden sm:inline">Contacta</span>
      </a>
      
      <!-- Mobile menu button -->
      <button class="md:hidden p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors" aria-label="Open menu">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </Container>
</header>