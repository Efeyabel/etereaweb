---
import Container from '../shared/Container.astro';
import Logo from '../shared/Logo.astro';
import Icon from '../shared/Icon.astro';
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-stone-200 dark:bg-background-dark py-12">
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 text-slate-900 dark:text-slate-100 mb-6">
          <Logo size="sm" />
          <span class="font-bold uppercase tracking-tight">Etérea Producciones</span>
        </div>
        <p class="text-slate-600 dark:text-slate-300 text-sm max-w-sm font-light leading-relaxed">
          Somos una empresa creativa especializada en la teatralización de eventos y producción teatral, dedicada a transformar cada ocasión en una experiencia inolvidable. Diseñamos y desarrollamos espectáculos a medida, combinando dramaturgia, puesta en escena, música, iluminación y talento artístico para dar vida a historias que conectan con el público.
        </p>
      </div>
      
      <div>
        {/* FIXED: Changed from h4 to h2 (since no h1/h2/h3 in footer, h2 is appropriate for sections) */}
        <h2 class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6">Conecta con nosotros</h2>
        <ul class="space-y-3">
          <li>
            <a href="https://www.instagram.com/eterea_producciones/" class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-instagram" size={16} />
              Instagram
            </a>
          </li>
        </ul>
      </div>
      
      <div>
        {/* FIXED: Changed from h4 to h2 (same level as "Connect") */}
        <h2 class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6">Contacto</h2>
        <p class="text-slate-900 dark:text-slate-100 text-sm font-medium mb-4 flex items-center gap-2">
          <Icon name="mail" size={16} class="text-primary" />
           info@etereaproducciones.es
        </p>
        <p class="text-slate-900 dark:text-slate-100 text-sm font-medium mb-4 flex items-center gap-2">
          <Icon name="phone" size={16} class="text-primary" />
           +34 604 92 15 16
        </p>
      </div>
    </div>
    
    <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium">
        2026 Fcodes. All Rights Reserved.
      </p>
    </div>
  </Container>
</footer>