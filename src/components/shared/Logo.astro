---
import { Image } from 'astro:assets';

/**
 * Mantenemos la ruta que ya te ha funcionado.
 */
import logoImage from '../../assets/img/logo.png';

export interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
}

const { class: className = '', size = 'md' } = Astro.props;

/**
 * Para que sea un círculo perfecto, necesitamos que el ancho (w) y el alto (h) 
 * sean iguales. He ajustado las clases para asegurar esta proporción 1:1.
 */
const sizeClasses = {
  sm: 'w-20 h-20',
  md: 'w-32 h-32',
  lg: 'w-48 h-48',
  xl: 'w-64 h-64'
};
---

<div class:list={[
  'inline-block', 
  'rounded-full',      /* Hace el contenedor circular */
  'overflow-hidden',   /* Recorta la imagen que sobresale del círculo */
  sizeClasses[size], 
  className
]}>
  <Image 
    src={logoImage} 
    alt="Etérea Producciones Logo" 
    class="w-full h-full object-cover"
    densities={[1.5, 2]}
    quality="max"
    loading="eager" 
  />
</div>